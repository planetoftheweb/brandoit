rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isNotDisabled(uid) {
      // A user cannot read/write as themselves if they've been marked disabled.
      // Admin override is checked by callers separately via isAdmin().
      return !(exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.isDisabled == true);
    }

    // Catalog resources (graphic_types, visual_styles, etc.) — must align with
    // resourceService.fetchScopedResources queries. Guests read system + public
    // only; signed-in users also read their private items and team-shared items.
    function isPublicCatalogScope() {
      return resource.data.scope in ['system', 'public'];
    }

    function isOwnPrivateCatalog() {
      return isSignedIn()
        && resource.data.scope == 'private'
        && resource.data.authorId == request.auth.uid;
    }

    function canReadTeamCatalog() {
      return isSignedIn()
        && resource.data.scope == 'team'
        && resource.data.teamId is string
        && exists(/databases/$(database)/documents/teams/$(resource.data.teamId))
        && (
          request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.ownerId
          || request.auth.uid in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.memberIds
        );
    }

    function canReadCatalogResource() {
      return isPublicCatalogScope()
        || isOwnPrivateCatalog()
        || canReadTeamCatalog()
        || isAdmin();
    }

    // ---- Username lookup (signup + login-by-username) ---------------------
    // Doc id is the normalized (lowercase) username. `get` is public so
    // pre-auth signup can check uniqueness and login can resolve email.
    match /usernames/{usernameKey} {
      allow get: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(usernameKey));
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if isAdmin();
    }

    // ---- Users ------------------------------------------------------------
    // Owner can read/write their own doc. Admins can read/write any user doc.
    // Admins can also list (enables paginated user table on the admin page).
    match /users/{uid} {
      allow get:    if isOwner(uid) || isAdmin();
      allow list:   if isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // History subcollection is owner-private; admins override.
      match /history/{docId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    // ---- Collection-group rule for admin usage-stats dashboard ----------
    // collectionGroup('history') queries evaluate against this wildcard path
    // (NOT the nested /users/{uid}/history rule above). Admin-only; owner-
    // scoped reads still flow through the nested rule with the specific uid.
    match /{path=**}/history/{docId} {
      allow read: if isAdmin();
    }

    // ---- Shared catalog collections --------------------------------------
    // system + public: readable without auth (guest studio + community catalog).
    // private + team: scoped per user/team. Writes still require sign-in.
    match /graphic_types/{docId} {
      allow read:   if canReadCatalogResource();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /visual_styles/{docId} {
      allow read:   if canReadCatalogResource();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /brand_colors/{docId} {
      allow read:   if canReadCatalogResource();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /aspect_ratios/{docId} {
      allow read:   if canReadCatalogResource();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ---- Teams ------------------------------------------------------------
    // Team owner or a listed member can read. Only the owner (or admin) can
    // modify the top-level doc. Member docs are managed by the owner + admin.
    match /teams/{teamId} {
      allow read:   if isSignedIn()
        && (resource.data.ownerId == request.auth.uid
            || request.auth.uid in resource.data.memberIds
            || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /{subPath=**} {
        allow read, write: if isSignedIn()
          && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds
              || isAdmin());
      }
    }

    // Everything else is denied by default.
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
